# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
API_PREFIX=/api
API_VERSION=v1

# ─── InfluxDB (time-series store) ────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=replace-with-your-influx-token
INFLUX_ORG=greenhouse
INFLUX_BUCKET=greenhouse
INFLUX_MEASUREMENT=sensor_reading

# ─── MQTT broker (HiveMQ Cloud) ──────────────────────────────────────────────
MQTT_URL=mqtts://your-cluster.s1.eu.hivemq.cloud:8883
MQTT_CLIENT_ID=smart-greenhouse-backend
MQTT_USERNAME=your-hivemq-username
MQTT_PASSWORD=your-hivemq-password
MQTT_TOPIC_PREFIX=greenhouse
# ESP32 firmware publishes one string per sensor under esp32s3/smartfarm/*
MQTT_SUBSCRIBE_TOPIC=esp32s3/smartfarm/+
MQTT_QOS=1
MQTT_RECONNECT_PERIOD_MS=5000
MQTT_CONNECT_TIMEOUT_MS=15000

# ─── ESP32 telemetry ─────────────────────────────────────────────────────────
# Topics carry no device id, so it is assigned here. Per-field messages are
# combined into one reading after ESP32_FLUSH_MS.
ESP32_DEVICE_ID=esp32-01
ESP32_FLUSH_MS=2000

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
# Toggle to "true" to require JWT on read endpoints
AUTH_ENABLED=false
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRES_IN=1d
ADMIN_EMAIL=admin@greenhouse.local
ADMIN_PASSWORD=ChangeMe123!

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
