# Copy to terraform.tfvars and fill in real values:
#   cp terraform.tfvars.example terraform.tfvars
# terraform.tfvars is git-ignored — never commit real secrets.

# ─── AWS / networking ────────────────────────────────────────────────────────
region       = "eu-central-1" # Frankfurt (match your EC2 key pair's region)
project_name = "greenhouse-demo"

# Name of an EXISTING EC2 key pair in the region above (create it in the console
# first and download the .pem). Required for SSH.
key_name = "your-ec2-keypair-name"

# CIDR allowed to reach SSH (22) and HTTP (80). Lock to your IP for safety:
#   "203.0.113.10/32". "0.0.0.0/0" opens to the whole internet (demo only).
allowed_cidr = "0.0.0.0/0"

instance_type = "t3.small" # 2 vCPU / 2 GB — enough for InfluxDB + Node build

# ─── Git (public repo cloned + built on first boot) ──────────────────────────
git_repo   = "https://github.com/sonusaji09-himmel/smart-greenhouse-backend.git"
git_branch = "main"

# ─── HiveMQ Cloud (use the SAME cluster/credentials as the ESP32) ────────────
mqtt_url      = "mqtts://your-cluster.s1.eu.hivemq.cloud:8883"
mqtt_username = "your-hivemq-username"
mqtt_password = "your-hivemq-password"

# ─── InfluxDB (initialized in Docker on the instance) ────────────────────────
influx_org    = "greenhouse"
influx_bucket = "greenhouse"
# Generate strong values, e.g.:
#   influx_token:    openssl rand -hex 32
#   influx_password: openssl rand -base64 18
influx_token    = "replace-with-a-long-random-token"
influx_password = "replace-with-strong-password"

# ─── Application ─────────────────────────────────────────────────────────────
auth_enabled = false # true requires a strong jwt_secret below
jwt_secret   = "replace-with-long-jwt-secret-min-16-chars"
cors_origins = "*"
